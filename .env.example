# ==========================================
# 智能温室AI助手系统 — 环境变量模板
# 复制此文件为 .env 并填入真实值
# ==========================================

# ── DeepSeek API (LLM 对话 + 智能顾问) ──
DEEPSEEK_API_KEY=sk-your_deepseek_api_key_here

# ── 智谱AI API (RAG 向量检索) ──
ZHIPU_API_KEY=your_zhipu_api_key_here

# ── MySQL 数据库 ──
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3307
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DB=ai_agent_memory2

# ── MQTT (EMQX Cloud) ──
MQTT_USERNAME=rpi_user
MQTT_PASSWORD=your_mqtt_password_here

# ── B站直播 (bilibili-api) ──
BILI_SESSDATA=your_bili_sessdata_here
BILI_JCT=your_bili_jct_here
BILI_BUVID3=your_bili_buvid3_here
BILI_DEDEUSERID=your_bili_dedeuserid_here

# ── 讯飞TTS ──
XUNFEI_APP_ID=your_xunfei_app_id_here
XUNFEI_API_KEY=your_xunfei_api_key_here
XUNFEI_API_SECRET=your_xunfei_api_secret_here
